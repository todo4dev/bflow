---
config:
  layout: elk
---
erDiagram
  direction LR

  %% =========================
  %% ACCOUNT
  %% =========================

  account {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    datetime deleted_at
    string email UK
    string status "pending|active|disabled|deleted"
  }

  account_profile {
    uuidv7 id PK
    datetime updated_at
    string first_name
    string last_name
    string picture
    uuidv7 account_id FK
  }

  account_configuration {
    uuidv7 id PK
    datetime updated_at
    string theme "light|dark|system"
    uuidv7 account_id FK
  }

  account_credential {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    datetime deleted_at
    string credential_type "password|google|microsoft"
    string provider_subject
    string password_hash
    uuidv7 account_id FK
  }

  account_certificate {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    datetime expires_at
    string fingerprint
    string subject
    string issuer
    string serial_number
    string encrypted_payload
    string encrypted_password
    datetime revoked_at
    uuidv7 account_id FK
  }

  account_email_activation {
    uuidv7 id PK
    datetime created_at
    datetime expires_at
    datetime used_at
    string token_hash
    uuidv7 account_id FK
  }

  account_password_reset {
    uuidv7 id PK
    datetime created_at
    datetime expires_at
    datetime used_at
    string token_hash
    uuidv7 account_id FK
  }

  account_session {
    uuidv7 id PK
    datetime created_at
    datetime expires_at
    datetime revoked_at
    string refresh_token_hash
    string user_agent
    string ip
    uuidv7 account_id FK
  }

  currency {
    string code PK "ISO 4217"
    string name
    int minor_unit
    string symbol
    boolean is_active_flag
    datetime created_at
    datetime updated_at
  }

  currency_exchange_rate {
    uuidv7 id PK
    datetime created_at
    datetime effective_at
    string base_currency_code FK
    string quote_currency_code FK
    decimal rate
    string source "manual|provider_name"
  }

  tenant {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    datetime deleted_at
    string subdomain UK
    string name
    string status "active|suspended|deleted"
    string picture
    string stripe_customer_id
  }

  tenant_configuration {
    uuidv7 id PK
    datetime updated_at
    string default_timezone "IANA, ex: America/Sao_Paulo"
    string default_currency_code FK
    uuidv7 tenant_id FK
  }

  tenant_currency {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    uuidv7 tenant_id FK
    string currency_code FK
    boolean is_enabled
  }

  tenant_subscription {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    string status "trialing|active|past_due|canceled"
    datetime start_at
    datetime end_at
    datetime cancel_at
    datetime canceled_at
    boolean is_cancel_at_period_end
    string stripe_subscription_id
    uuidv7 tenant_id FK
    uuidv7 billing_plan_id FK
  }

  billing_plan {
    uuidv7 id PK
    datetime created_at
    string code UK
    string name
    string period "monthly|yearly"
    boolean is_active_flag
  }

  billing_invoice {
    uuidv7 id PK
    datetime created_at
    string status "draft|open|paid|void|uncollectible"
    string currency_code FK
    decimal total_amount
    decimal total_tax_amount
    decimal total_discount_amount
    datetime issued_at
    datetime due_at
    datetime paid_at
    string stripe_invoice_id
    string stripe_payment_intent_id
    uuidv7 tenant_id FK
    uuidv7 tenant_subscription_id FK
  }

  billing_payment {
    uuidv7 id PK
    datetime created_at
    string status "pending|succeeded|failed|refunded"
    decimal amount
    datetime paid_at
    string stripe_payment_intent_id
    uuidv7 billing_invoice_id FK
  }

  stripe_webhook_event {
    uuidv7 id PK
    datetime created_at
    datetime processed_at
    string stripe_event_id UK "evt_..."
    string stripe_event_type
    string stripe_object_type "invoice|payment_intent|subscription|..."
    string stripe_object_id "in_|pi_|sub_|..."
    uuidv7 tenant_id FK
  }

  membership {
    uuidv7 id PK
    datetime created_at
    datetime updated_at
    datetime removed_at
    string role "admin|manager|member"
    string status "invited|active|suspended|removed"
    uuidv7 invited_by_membership_id FK
    uuidv7 tenant_id FK
    uuidv7 account_id FK
  }

  membership_invitation {
    uuidv7 id PK
    datetime created_at
    datetime expires_at
    datetime accepted_at
    datetime revoked_at
    string invited_email_address
    string role "admin|manager|member"
    uuidv7 invited_by_membership_id FK
    string invitation_token_hash
    uuidv7 tenant_id FK
  }

  account_profile |o--|| account : "has"
  account_configuration |o--|| account : "has"
  account_credential }o--|| account : "has"
  account_certificate }o--|| account : "has"
  account_email_activation }o--|| account : "has"
  account_password_reset }o--|| account : "has"
  account_session }o--|| account : "has"

  account ||--o{ membership : "has"
  membership }o--|| tenant  : "has"

  membership ||--o{ membership_invitation : "invites"
  membership_invitation }o--|| tenant  : "has"

  tenant ||--o{ tenant_subscription : "has"
  tenant ||--o| tenant_configuration : "has"
  tenant ||--o{ billing_invoice : "has"

  tenant_subscription ||--o{ billing_invoice : "generates"
  tenant_subscription }o--|| billing_plan  : "selected"

  billing_invoice ||--o{ billing_payment : "receives"

  tenant ||--o{ stripe_webhook_event : "receives"

  currency ||--o{ currency_exchange_rate : "base"
  currency ||--o{ currency_exchange_rate : "quote"

  tenant_configuration }o--|| currency : "default"
  tenant ||--o{ tenant_currency : "supports"
  tenant_currency }o--|| currency : "enabled"
  currency ||--o{ billing_invoice : "invoice_currency"
