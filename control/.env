# docker

DOCKER_POSTGRES_PORT=25432
DOCKER_POSTGRES_USERNAME=postgres
DOCKER_POSTGRES_PASSWORD=postgres
DOCKER_POSTGRES_DATABASE=postgres

DOCKER_LIQUIBASE_TAG=1766409416304

DOCKER_DRAGONFLY_PORT=26379

DOCKER_MINIO_API_PORT=28001
DOCKER_MINIO_REGION=us-east-1
DOCKER_MINIO_BUCKET=control
DOCKER_MINIO_CONSOLE_PORT=28000
DOCKER_MINIO_ROOT_USER=minio_user
DOCKER_MINIO_ROOT_PASSWORD=minio_password

DOCKER_KAFKA_PORT=29092
DOCKER_KAFKA_UI_PORT=29000

# application

CACHE_REDIS_URI="redis://localhost:${DOCKER_DRAGONFLY_PORT}/0"

CRYPTO_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

DATABASE_POSTGRES_URI="postgres://${DOCKER_POSTGRES_USERNAME}:${DOCKER_POSTGRES_PASSWORD}@localhost:${DOCKER_POSTGRES_PORT}/${DOCKER_POSTGRES_DATABASE}?sslmode=disable&options=-c%20search_path%3Dcontrol_plane,public"
DATABASE_DEFAULT_LIMIT=100

JWT_ALGORITHM=HS256
JWT_AUDIENCE=http://localhost:4000
JWT_ISSUER=http://localhost:4000
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_PRIVATE_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_PUBLIC_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

LOGGER_LEVEL=info

MAILER_DEFAULT_FROM=no-reply@localhost
MAILER_SMTP_HOSTNAME=localhost
MAILER_SMTP_PORT=25
MAILER_SMTP_SECURE=false
MAILER_SMTP_IGNORE_TLS=false
MAILER_SMTP_USERNAME=
MAILER_SMTP_PASSWORD=

OPENID_BASE_URI=http://localhost:4000
OPENID_MICROSOFT_CLIENT_ID="{{OPENID_MICROSOFT_CLIENT_ID}}"
OPENID_MICROSOFT_CLIENT_SECRET="{{OPENID_MICROSOFT_CLIENT_SECRET}}"
OPENID_MICROSOFT_CALLBACK_URI="{{OPENID_MICROSOFT_CALLBACK_URI}}"
OPENID_GOOGLE_CLIENT_ID="{{OPENID_GOOGLE_CLIENT_ID}}"
OPENID_GOOGLE_CLIENT_SECRET="{{OPENID_GOOGLE_CLIENT_SECRET}}"
OPENID_GOOGLE_CALLBACK_URI="{{OPENID_GOOGLE_CALLBACK_URI}}"

STORAGE_ENDPOINT="http://localhost:${DOCKER_MINIO_API_PORT}"
STORAGE_REGION="${DOCKER_MINIO_REGION}"
STORAGE_BUCKET="${DOCKER_MINIO_BUCKET}"
STORAGE_ACCESS_KEY_ID="${DOCKER_MINIO_ROOT_USER}"
STORAGE_SECRET_ACCESS_KEY="${DOCKER_MINIO_ROOT_PASSWORD}"

STREAM_KAFKA_URI="localhost:${DOCKER_KAFKA_PORT}"
